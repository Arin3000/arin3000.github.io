<article class="article-page section-reveal">
  <header class="article-hero">
    <p class="eyebrow"><%= page.categories && page.categories.length ? page.categories.first().name : 'Note' %></p>
    <h1><%= page.title %></h1>
    <time><%= date(page.date, 'YYYY.MM.DD') %></time>
    <% if (page.cover) { %>
      <img src="<%- url_for(page.cover) %>" alt="">
    <% } %>
  </header>
  <div class="article-content">
    <%- page.content %>
  </div>
</article>
