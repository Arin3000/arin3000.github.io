<article class="article-page section-reveal">
  <header class="article-hero <%= page.cover ? 'has-cover' : '' %>">
    <% if (page.cover) { %>
      <div class="article-meta-outside">
        <p class="eyebrow"><%= page.categories && page.categories.length ? page.categories.first().name : 'Note' %></p>
        <time><%= date(page.date, 'YYYY.MM.DD') %></time>
      </div>
      <img src="<%- url_for(page.cover) %>" alt="">
      <div class="article-hero-copy">
        <h1><%= page.title %></h1>
      </div>
    <% } else { %>
      <p class="eyebrow"><%= page.categories && page.categories.length ? page.categories.first().name : 'Note' %></p>
      <h1><%= page.title %></h1>
      <time><%= date(page.date, 'YYYY.MM.DD') %></time>
    <% } %>
  </header>
  <div class="article-content">
    <%- page.content %>
  </div>
</article>
